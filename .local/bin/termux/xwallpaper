#!/bin/sh

# xwallpaper wrapper for Termux

if [ -n "$TMUX" ]; then
	for o in $@ ; do case "$o" in
		--o*|--sc*|--tr*) shift 2 ;;
		--*) shift ;;
	esac ; done
	[ -f "$1" ] || { echo "File not found: $1" ; exit 1 ;}
	file="$(readlink -f "$1")"
	termux-wallpaper -f "$file" >/dev/null 2>&1
	termux-wallpaper -l -f "$file" >/dev/null 2>&1
else
	"$PREFIX"/bin/xwallpaper "$@"
fi
