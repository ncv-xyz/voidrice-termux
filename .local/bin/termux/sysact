#!/bin/sh

# sysact script wrapper for Termux

if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then

	lock="🔒 wake lock"
	[ -f "$PREFIX/tmp/lock" ] && lock="🔓 wake unlock"

	lock() {
		case "${lock##* }" in
			lock) cp /dev/null "$PREFIX/tmp/lock" ;;
			unlock) rm -f "$PREFIX/tmp/lock" ;;
		esac
		termux-wake-${lock##* }
	}

	case "$(printf "$lock\n🚪 leave tmux\n♻️ renew termux\n🖥️shutdown" | dmenu -i -p 'Action: ')" in
		"$lock") lock ;;
		'🚪 leave tmux') tmux kill-session ;;
		'♻️ renew termux') termux-reload-settings ;;
		'🖥️shutdown') kill -TERM $(pidof com.termux) ;;
		*) exit 1 ;;
	esac

else
	"$HOME"/.local/bin/sysact
fi
