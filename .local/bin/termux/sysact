#!/bin/sh

# sysact script wrapper for Termux

if [ -n "${TMUX}" ]; then
	lockfile="${XDG_CACHE_HOME:-$HOME/.cache}/termux_lock"
	lock='🔒 wake lock'
	[ -f "${lockfile}" ] && lock='🔓 wake unlock'
	lock() {
		case "${lock##* }" in
			lock) cp /dev/null "${lockfile}" ;;
			unlock) rm "${lockfile}" ;;
		esac
		notify-send "${lock}ed."
		termux-wake-"${lock##* }"
	}
	tmuxconf="${XDG_CONFIG_HOME:-${HOME}/.config}/tmux/tmux.conf"
	case "$(printf %s\\n "${lock}" '🚪 leave tmux' '♻️ renew termux' '🖥️shutdown' | dmenu -i -p 'Action: ')" in
		*lock*) lock ;;
		*leave*) tmux kill-session ;;
		*renew*) tmux source "${tmuxconf}" 2>/dev/null ;;
		*shutdown*) kill -TERM "$(pidof com.termux)" ;;
	esac
else
	"${HOME}/.local/bin/sysact"
fi
