#!/bin/sh

# xdotool wrapper for Termux

if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then
	[ "$1" = "type" ] && shift || exit
	for o in $@ ; do case "$o" in
		--f*) file=1 ; shift ;;
		--[wd*]) shift 2 ;;
		-*) shift ;;
	esac done
	[ -z "$file" ] || input="$(cat "${1:-$([ -t 0 ] || xargs)}")"
	input="${input:-${@:-$([ -t 0 ] || xargs)}}"
	[ -z "$input" ] || termux-clipboard-set "$input"
else
	"$PREFIX"/bin/xdotool "$@"
fi
