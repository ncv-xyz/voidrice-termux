#!/bin/sh

# sb-battery wrapper for Termux

state="$(termux-wifi-connectioninfo | grep "supplicant")"
state="${state%\"*}"
state="${state##*\"}"

case "$state" in
	"COMPLETED") wifiicon="$(termux-wifi-connectioninfo | awk '/rssi/ { print "📶", int( ($2 + 110) * 10 / 7) "% " }')" ;;
	"DISCONNECTED") wifiicon="📡 " ;;
	"UNINITIALIZED") ;;
	*) wifiicon="❌ " ;;
esac

printf "%s%s\n" "$wifiicon" "❎"
