#!/bin/sh

# mimeopen wrapper for Termux

if [ -n "$TMUX" ]; then
	for o in "$@"; do case "$o" in
		-a|--ask) command="termux-share" ;;
		-*) ;;
		*) args="$args $o" ;;
	esac done
	set -- "${args# }"
	${command:-termux-share -d} \
		"${1:-$([ -t 0 ] || xargs)}"
else
	"$PREFIX/bin/vendor_perl/mimeopen" "$@"
fi
