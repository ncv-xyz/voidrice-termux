#!/bin/sh

# mimeopen wrapper for Termux

if [ -n "${TMUX}" ]; then
	cmd="termux-share -d"
	for o in "${@}"; do case "${o}" in
		-a|--ask) cmd="${cmd% *}" ;;
		-*) ;;
		*) args="${args} ${o}" ;;
	esac done
	set -- "${args# }"
	${cmd} "${1:-$([ -t 0 ] || xargs)}"
else
	"${PREFIX}/bin/${0##*/}" "${@}"
fi
