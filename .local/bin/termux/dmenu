#!/bin/sh

# dmenu wrapper for fzf

if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then

	for o in $@ ; do case "$o" in
		-b) layout=default ; shift ;;
		-i) case="-i" ; shift ;;
		-l) height="$2" ; shift 2 ;;
		-p) prompt="$2" ; shift 2 ;;
		-f) shift ;;
		-nb) color_nb="$2" ; shift 2 ;;
		-nf) color_nf="$2" ; shift 2 ;;
		-sb) color_sb="$2" ; shift 2 ;;
		-sf) color_sf="$2" ; shift 2 ;;
		-[mw]) shift 2 ;;
		-*) shift ;;
	esac done

	[ -t 0 ] || items="$(xargs -0)"
	height="${height:-$(echo -n "$items" | wc -l)}"
	case 1 in
		$((height > $(tput lines))) ) height="100%" ;;
		$((height < 1)) ) height="100%" ; tmux_height="40%" ;;
		* ) height="$((height + 2))" ;;
	esac

	# dmenu format
	FZF_DEFAULT_OPTS="--no-info \
		--no-separator \
		--no-scrollbar \
		--prompt='$prompt' \
		--gutter=' ' \
		--pointer='' \
		--ellipsis='' \
		--highlight-line \
		--no-hscroll \
		--raw \
		--border=none \
		--layout=${layout:-reverse} \
		--height=$height \
		--tmux=top,100%,${tmux_height:-$height} \
		${case:-+i} \
		--preview-window=''"

	# dmenu keybinds
	FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS \
		--bind=change:best \
		--bind=tab:yank \
		--bind=ctrl-i:yank \
		--bind=ctrl-y:yank \
		--bind=ctrl-Y:yank \
		--bind=enter:accept \
		--bind=ctrl-j:accept \
		--bind=ctrl-J:accept \
		--bind=ctrl-m:accept \
		--bind=ctrl-M:accept \
		--bind=esc:abort \
		--bind=ctrl-c:abort \
		--bind=ctrl-g:abort \
		--bind=ctrl-left:backward-word \
		--bind=alt-b:backward-word \
		--bind=ctrl-right:forward-word \
		--bind=alt-f:forward-word \
		--bind=ctrl-a:first \
		--bind=alt-g:first \
		--bind=ctrl-b:up \
		--bind=ctrl-p:up \
		--bind=alt-h:up \
		--bind=ctrl-d:delete-char \
		--bind=ctrl-e:last \
		--bind=alt-G:last \
		--bind=ctrl-f:down \
		--bind=ctrl-n:down \
		--bind=alt-l:down \
		--bind=ctrl-h:backward-delete-char \
		--bind=ctrl-k:kill-word \
		--bind=ctrl-u:kill-line \
		--bind=ctrl-w:backward-kill-word \
		--bind=alt-j:page-down \
		--bind=alt-k:page-up"

	# wal colors
	wal_dmenu="${XDG_CACHE_DIR:-$HOME/.cache}/wal/colors-wal-dmenu.h"
	if command -v wal >/dev/null 2>&1 && [ -f "$wal_dmenu" ]; then
		color_nb="${color_nb:-$(grep "SchemeNorm" "$wal_dmenu")}"
		color_nb="${color_nb%\"*}"
		color_nb="${color_nb##*\"}"
		color_nf="${color_nf:-$(grep "SchemeNorm" "$wal_dmenu")}"
		color_nf="${color_nf#*\"}"
		color_nf="${color_nf%%\"*}"
		color_sb="${color_sb:-$(grep "SchemeSel" "$wal_dmenu")}"
		color_sb="${color_sb%\"*}"
		color_sb="${color_sb##*\"}"
		color_sf="${color_sf:-$(grep "SchemeSel" "$wal_dmenu")}"
		color_sf="${color_sf#*\"}"
		color_sf="${color_sf%%\"*}"
		color_ob="$(grep "SchemeOut" "$wal_dmenu")"
		color_ob="${color_ob%\"*}"
		color_ob="${color_ob##*\"}"
		color_of="$(grep "SchemeOut" "$wal_dmenu")"
		color_of="${color_of#*\"}"
		color_of="${color_of%%\"*}"
	fi

	# dmenu colors
	FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS \
		--color=list-fg:${color_nf:-#bbbbbb} \
		--color=hl:${color_nf:-#bbbbbb} \
		--color=prompt:${color_nf:-#bbbbbb}:regular \
		--color=nomatch:regular \
		--color=list-bg:${color_nb:-#222222} \
		--color=fg+:${color_sf:-#eeeeee} \
		--color=hl+:${color_sf:-#eeeeee} \
		--color=query:${color_nf:-#bbbbbb} \
		--color=bg+:${color_sb:-#005577} \
		--color=marker:${color_ob:-#00ffff}"

	if [ "${0##*/}" = "dmenu_run" ]; then
		cache="${XDG_CACHE_HOME:-$HOME/.cache}/dmenu_run"
		[ ! -d "${cache%/*}" ] && mkdir -p "${cache%/*}"
		echo -n "$PATH" | xargs -d":" -I {} find {} -maxdepth 1 -executable -type f -printf "%P\n" | tee "$cache" >/dev/null 2>&1
		cat "$cache" | sort -u | fzf | xargs setsid -f >/dev/null 2>&1
	else
		echo "$items" | fzf
	fi

else
	"$PREFIX"/bin/dmenu "$@"
fi
