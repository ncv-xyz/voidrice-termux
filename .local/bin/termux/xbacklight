#!/bin/sh

# xbacklight wrapper for Termux

for o in "$@"; do case "$o" in
	-de*) brightness="$((100 - $2))" ; shift 2 ;;
	-i*|-se*) brightness="$2" ; shift 2 ;;
	-[hg]*) shift ;;
	-*) shift 2 ;;
esac done

[ -z "$brightness" ] && exit 1

brightness="$(( brightness * 255 / 100 ))"

termux-brightness $brightness
