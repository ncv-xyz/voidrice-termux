#!/bin/sh

# lfub script wrapper for Termux

if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then
	lf -command \
		"set promptfmt \"\033[32;1m$USER@$HOST\033[0m:\033[34;1m%d\033[0m\033[1m%f\033[0m\" ; \
		set statfmt \"\033[36m%p\033[0m| %c| $USER| wheel| %S| %t| -> %l\" ; \
		set rulerfmt \"   %a|  %p|  \033[7;31m %m \033[0m|  \033[7;33m %c \033[0m|  \033[7;35m %s \033[0m|  \033[7;36m %v \033[0m|  \033[7;34m %f \033[0m|  %i/%t\"" \
		"$@"
else
	"$HOME"/.local/bin/lfub "$@"
fi
